      <column caption='Return Period ' datatype='real' name='[Calculation_2390070181695493]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;&#10;WHEN &quot;1M&quot; THEN [Return_1M_pct]&#10;&#10;WHEN &quot;3M&quot; THEN [Return_3M_pct]&#10;&#10;WHEN &quot;6M&quot; THEN [Return_6M_pct]&#10;&#10;WHEN &quot;12M&quot; THEN [Return_1Y_pct]&#10;&#10;WHEN &quot;36M&quot; THEN [Return_3Y_pct]&#10;&#10;END' />
      </column>
      <column caption='Up or Down arrow' datatype='string' name='[Calculation_2390070184808454]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF  AVG([Calculation_2390070181695493]) &gt; 0  &#10;&#10;&#10;THEN &apos;▲&apos; ELSE &apos;▼&apos; &#10;END' />
      </column>
      <column caption='ETF Rank ' datatype='integer' name='[Calculation_2390070187544583]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(AVG([Calculation_2390070181695493]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top Bottom Filter' datatype='boolean' name='[Calculation_2390070187835400]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(AVG([Calculation_2390070181695493])) &lt;= 5&#10;OR&#10;RANK(AVG([Calculation_2390070181695493]), &apos;asc&apos;) &lt;= 5'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Color Logic' datatype='string' name='[Calculation_2390070188421129]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_2390070181695493]) &gt; 0 THEN &quot;Positive&quot;&#10;ELSE &quot;Negative&quot;&#10;END' />
      </column>
      <column caption='Filter Outlier for Risk and Return' datatype='boolean' name='[Calculation_2390070201716746]' role='measure' type='nominal'>
        <calculation class='tableau' formula='ABS(AVG([Calculation_2390070181695493])) &lt; 50&#10;AND&#10;AVG([Volatility_30D]) &lt; 10' />
      </column>
      <column caption='Total ETFs' datatype='integer' name='[Calculation_2390070208667659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([ETF_Name])' />
      </column>
      <column caption='Avg Return Period' datatype='real' name='[Calculation_2390070208954380]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_2390070181695493])' />
      </column>
      <column caption='Top ETF Name' datatype='string' name='[Calculation_2390070231490574]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_2390070181695493]) = WINDOW_MAX(AVG([Calculation_2390070181695493]))&#10;THEN MIN([ETF_Name])&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top  ETF Return' datatype='real' name='[Calculation_2390070232223759]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF AVG([Calculation_2390070181695493]) = WINDOW_MAX(AVG([Calculation_2390070181695493]))&#10;THEN AVG([Calculation_2390070181695493])&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Lowest Risk ETF' datatype='string' name='[Calculation_2390070233010192]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Volatility_30D]) = WINDOW_MIN(AVG([Volatility_30D]))&#10;THEN MIN([ETF_Name])&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Lowest Risk ETF volatility' datatype='real' name='[Calculation_2390070233251857]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF AVG([Volatility_30D]) = WINDOW_MIN(AVG([Volatility_30D]))&#10;THEN AVG([Volatility_30D])&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Volatility' datatype='real' name='[Calculation_2390070238257170]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Volatility_30D])' />
      </column>

      <aliases enabled='yes' />
      <column caption='Accident Severity' datatype='string' name='[Accident_Severity]' role='dimension' type='nominal' />
      <column caption='PY Accidents ' datatype='integer' name='[CY Accidents (copy)_2009844984418309]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF YEAR([Accident Date]) = [Parameters].[Current Year (copy)_2009844983287810] &#10;THEN [Index]&#10;END)' />
      </column>
      <column caption='CY Casualties' datatype='integer' name='[CY Accidents (copy)_2009844986417159]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF  YEAR([Accident Date]) = [Parameters].[Parameter 1] &#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column caption='Fatal CY Casulaties' datatype='integer' name='[CY Accidents (copy)_2009844989288458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Parameter 1] AND &#10;[Accident_Severity] = &apos;Fatal&apos;&#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column aggregation='Sum' caption='Year of Accident' datatype='integer' name='[Calculation_2009844982136833]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='YEAR([Accident Date])' />
      </column>
      <column caption='CY Accidents' datatype='integer' name='[Calculation_2009844983476227]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF YEAR([Accident Date]) = [Parameters].[Parameter 1] &#10;THEN [Index]&#10;END)' />
      </column>
      <column caption='YOY Accident Change' datatype='real' default-format='*▲ 00.00% ; ▼00.00%' name='[Calculation_2009844984336388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2009844983476227] - [CY Accidents (copy)_2009844984418309])/([CY Accidents (copy)_2009844984418309])' />
      </column>
      <column caption='Find CY' datatype='string' name='[Calculation_2009845008498707]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([Accident Date]) = [Parameters].[Parameter 1]&#10;THEN DATENAME(&apos;month&apos;,[Accident Date])&#10;END' />
      </column>
      <column caption='Accident Severity Filer' datatype='boolean' name='[Calculation_2099592717570048]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2] = [Accident_Severity]&#10;OR [Parameters].[Parameter 2] = &apos;All&apos;' />
      </column>
      <column caption='Fatal PY Casualties' datatype='integer' name='[Fatal CY Accidents  (copy)_2009844989726731]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Current Year (copy)_2009844983287810] AND &#10;[Accident_Severity] = &apos;Fatal&apos;&#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column caption='Serious CY Casulaties ' datatype='integer' name='[Fatal CY Casulaties (copy)_2009845006675981]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Parameter 1] AND &#10;[Accident_Severity] = &apos;Serious&apos;&#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column caption='Slight CY Casulaties ' datatype='integer' name='[Fatal CY Casulaties (copy)_2009845007585296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Parameter 1] AND &#10;[Accident_Severity] = &apos;Slight&apos;&#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column caption='Serious PY Casualties ' datatype='integer' name='[Fatal PY Casualties (copy)_2009845006684174]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Current Year (copy)_2009844983287810] AND &#10;[Accident_Severity] = &apos;Serious&apos;&#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column caption='Slight PY Casualties ' datatype='integer' name='[Fatal PY Casualties (copy)_2009845007593489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Current Year (copy)_2009844983287810] AND &#10;[Accident_Severity] = &apos;Slight&apos;&#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column caption='Find PY' datatype='integer' name='[Find CY (copy)_2009845008662548]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Accident Date]) = [Parameters].[Current Year (copy)_2009844983287810] THEN YEAR([Accident Date])&#10;END' />
      </column>
      <column aggregation='Avg' datatype='real' name='[Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column caption='Light Conditions' datatype='string' name='[Light_Conditions]' role='dimension' type='nominal' />
      <column aggregation='Avg' datatype='real' name='[Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column caption='Number of Casualties' datatype='integer' name='[Number_of_Casualties]' role='measure' type='quantitative' />
      <column caption='Number of Vehicles' datatype='integer' name='[Number_of_Vehicles]' role='measure' type='quantitative' />
      <column caption='PY Casualties' datatype='integer' name='[PY Accidents  (copy)_2009844986441736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date]) = [Parameters].[Current Year (copy)_2009844983287810] &#10;THEN [Number_of_Casualties]&#10;END)' />
      </column>
      <column datatype='string' name='[Road Surface Conditions (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[Road_Surface_Conditions]' new-bin='true'>
          <bin default-name='false' value='&quot;Snow&quot;'>
            <value>&quot;Frost or ice&quot;</value>
            <value>&quot;Snow&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Unknown&quot;'>
            <value>%null%</value>
          </bin>
          <bin default-name='false' value='&quot;Wet&quot;'>
            <value>&quot;Flood over 3cm. deep&quot;</value>
            <value>&quot;Wet or damp&quot;</value>
          </bin>
        </calculation>
      </column>
      <column caption='Road Surface Conditions' datatype='string' name='[Road_Surface_Conditions]' role='dimension' type='nominal' />
      <column caption='Road Type' datatype='string' name='[Road_Type]' role='dimension' type='nominal' />
      <column caption='Urban or Rural Area' datatype='string' name='[Urban_or_Rural_Area]' role='dimension' type='nominal' />
      <column datatype='string' name='[Vehicle Type (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[Vehicle_Type]' new-bin='true'>
          <bin default-name='false' value='&quot;Bus&quot;'>
            <value>&quot;Bus or coach (17 or more pass seats)&quot;</value>
            <value>&quot;Minibus (8 - 16 passenger seats)&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Car&quot;'>
            <value>&quot;Car&quot;</value>
            <value>&quot;Taxi/Private hire car&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Motorcycle&quot;'>
            <value>&quot;Motorcycle 125cc and under&quot;</value>
            <value>&quot;Motorcycle 50cc and under&quot;</value>
            <value>&quot;Motorcycle over 125cc and up to 500cc&quot;</value>
            <value>&quot;Motorcycle over 500cc&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Others&quot;'>
            <value>&quot;Data missing or out of range&quot;</value>
            <value>&quot;Other vehicle&quot;</value>
            <value>&quot;Pedal cycle&quot;</value>
            <value>&quot;Ridden horse&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Van&quot;'>
            <value>&quot;Goods 7.5 tonnes mgw and over&quot;</value>
            <value>&quot;Goods over 3.5t. and under 7.5t&quot;</value>
            <value>&quot;Van / Goods 3.5 tonnes mgw or under&quot;</value>
          </bin>
        </calculation>
      </column>
      <column caption='Vehicle Type' datatype='string' name='[Vehicle_Type]' role='dimension' type='nominal' />
      <column datatype='string' name='[Weather Conditions (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[Weather_Conditions]' new-bin='true'>
          <bin default-name='false' value='&quot;Fine&quot;'>
            <value>&quot;Fine + high winds&quot;</value>
            <value>&quot;Fine no high winds&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Others&quot;'>
            <value>%null%</value>
            <value>&quot;Other&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Raining&quot;'>
            <value>&quot;Raining + high winds&quot;</value>
            <value>&quot;Raining no high winds&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Snowing&quot;'>
            <value>&quot;Fog or mist&quot;</value>
            <value>&quot;Snowing + high winds&quot;</value>
            <value>&quot;Snowing no high winds&quot;</value>
          </bin>
